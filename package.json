{
  "name": "angular-main-structure",
  "version": "19.0.0",
  "scripts": {
    "ng": "node node_modules/@angular/cli/bin/ng",
    "start": "node node_modules/@angular/cli/bin/ng serve",
    "build": "node node_modules/@angular/cli/bin/ng build --configuration production && npm run sentry:sourcemaps",
    "watch": "node node_modules/@angular/cli/bin/ng build --watch --configuration development",
    "test": "node node_modules/@angular/cli/bin/ng test",
    "compodoc:build": "compodoc -p tsconfig.doc.json",
    "compodoc:build-and-serve": "compodoc -p tsconfig.doc.json -s",
    "compodoc:serve": "compodoc -s",
    "lint": "node node_modules/@angular/cli/bin/ng lint",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org hcm-ute --project def-fe-catcher ./dist && sentry-cli sourcemaps upload --org hcm-ute --project def-fe-catcher ./dist"
  },
  "private": true,
